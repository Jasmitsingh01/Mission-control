PORT=4000
MONGODB_URI=mongodb://localhost:27017/agentforge
JWT_SECRET=change-me-to-a-strong-random-secret-min-32-chars
APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# OpenRouter AI
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_DEFAULT_MODEL=google/gemini-2.0-flash-001

# Stripe Billing (leave blank to disable billing features)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=

# OpenClaw integration (optional)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Telegram Bot (optional — get token from @BotFather on Telegram)
# TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
